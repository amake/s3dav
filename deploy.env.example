# Copy this file to deploy.env and fill it out once.

stack_name=dav-s3-gateway
service_name=dav-s3-gateway

# S3 location for the Lambda ZIP artifact uploaded by `make deploy`.
artifact_bucket=my-artifact-bucket
artifact_key=dav-s3-gateway/lambda.zip

# Public endpoint configuration.
domain_name=dav.example.com
certificate_arn=arn:aws:acm:ap-northeast-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Leave empty if DNS is managed outside Route 53.
hosted_zone_id=

# Private storage backing the service itself.
s3_bucket=my-private-bucket
s3_prefix=webdav/

# Basic Auth credentials served by the gateway.
auth_username=alice
auth_password=replace-me

# Default upload limit: 5 MiB.
max_object_size_bytes=5242880
